# Base API URL for your backend services
# Default: http://localhost:3000
BASE_URL=http://localhost:3000

# Authentication URL - where users should be redirected for login
# Set this to your external auth service URL, or leave as default for local token setup
# Default: /set-token (uses internal token setup page)
AUTH_URL=https://your-auth-service.com/login

# Cookie name for storing the access token
# Default: accessToken
ACCESS_TOKEN_COOKIE_NAME=accessToken

# Cookie name for storing the refresh token
# Default: refreshToken
REFRESH_TOKEN_COOKIE_NAME=refreshToken

# Example with external auth service:
# AUTH_URL=https://auth.example.com/login
# BASE_URL=https://api.example.com

# Example for local development:
# AUTH_URL=/set-token
# BASE_URL=http://localhost:3000